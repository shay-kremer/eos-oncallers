# Database
DATABASE_URL=postgresql://oncall:oncall@localhost:5432/oncall

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Auth
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=24h

# Slack Integration (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Twilio Integration (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Datadog Integration (optional)
DATADOG_API_KEY=
DATADOG_APP_KEY=

# AWS Webhook (optional)
AWS_WEBHOOK_URL=

# Seed credentials (optional — auto-generated if not set)
SEED_ADMIN_EMAIL=admin@oncall.local
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD=
